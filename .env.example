# ──────────────────────────────────────────────
#  AI News Digest — Environment Configuration
# ──────────────────────────────────────────────

# Gemini API Key (https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail sender account (the Gmail address you'll SEND FROM)
GMAIL_SENDER=your_gmail_address@gmail.com

# Gmail App Password (NOT your normal password!)
# How to create: Google Account → Security → 2-Step Verification → App Passwords
# Select "Mail" and "Windows Computer", then copy the 16-char password
GMAIL_APP_PASSWORD=your_16_char_app_password

# Recipient email
DIGEST_RECIPIENT=as2020323@sci.sjp.ac.lk

# Digest delivery time — 7:30 AM SL time (UTC+5:30)
SCHEDULE_HOUR=7
SCHEDULE_MINUTE=30
